# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key

# PostgreSQL + pgvector (Amazon RDS)
DATABASE_URL=postgresql://postgres:password@tu-rds-endpoint.rds.amazonaws.com:5432/rag_master

# S3 Bucket para PDFs
S3_BUCKET_NAME=rag-master-pdfs

# Modelos Bedrock
BEDROCK_CLAUDE_MODEL_ID=us.anthropic.claude-opus-4-6-20250610-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
