# AWS Credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key

# PostgreSQL + pgvector (Amazon RDS)
DATABASE_URL=postgresql://postgres:password@tu-rds-endpoint.rds.amazonaws.com:5432/rag_master

# S3 Bucket para PDFs
S3_BUCKET_NAME=rag-master-pdfs

# Modelos Bedrock
BEDROCK_CLAUDE_MODEL_ID=us.anthropic.claude-opus-4-6-20250610-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Candado del admin: token compartido (fallback para el smoke test / automatización).
# El login humano usa la cookie de sesión de abajo; este token se conserva para no
# romper el smoke post-deploy. Fail-closed: si NO hay ni AUTH_SECRET ni este token,
# el admin queda bloqueado (503).
ADMIN_ACCESS_TOKEN=

# ── Login real del taller (autenticación por cookie de sesión JWT) ──
# AUTH_SECRET: secreto para firmar el JWT de sesión (HS256).
#   Genera uno: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=
# ADMIN_EMAIL: correo con el que inicias sesión.
ADMIN_EMAIL=
# ADMIN_PASSWORD_HASH: hash bcrypt de tu contraseña.
#   Genera: node -e "console.log(require('bcryptjs').hashSync('TU_CONTRASEÑA', 12))"
#   OJO: en un .env LOCAL escapa los '$' como '\$' (Next expande $VAR). En AWS/CI va literal.
ADMIN_PASSWORD_HASH=

# ── OpenAI — generación de imágenes (gpt-image) para El Taller / publicación ──
OPENAI_API_KEY=
# Opcional: id del modelo de imagen (default gpt-image-2) y calidad (low|medium|high).
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

# ── Serper.dev — capa "internet en general" del buscador de referencias visuales ──
# Opcional: Google Images real para las referencias del generador (≥5 por imagen).
# Sin llave, el buscador usa solo proveedores abiertos (Openverse/Wikimedia/Met).
SERPER_API_KEY=
