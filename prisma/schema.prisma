generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum DeliverableStatus {
  PENDING
  GENERATING
  COMPLETE
  ERROR
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum ChunkStrategy {
  FIXED
  PARAGRAPH
  SENTENCE
}

model Document {
  id        String         @id @default(cuid())
  filename  String
  s3Key     String
  s3Url     String
  fileSize  Int
  fileHash  String?
  pageCount Int            @default(0)
  status    DocumentStatus @default(PENDING)
  metadata  Json           @default("{}")
  enriched  Boolean        @default(false)
  error     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  chunks    Chunk[]
  questions Question[]

  @@index([fileHash])
  @@map("documents")
}

model Question {
  id                     String   @id @default(cuid())
  documentId             String
  document               Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  questionNumber         Int
  pregunta               String   @db.Text

  // Período histórico principal
  periodoCode            String
  periodoNombre          String
  periodoRango           String

  // Categoría principal
  categoriaCode          String
  categoriaNombre        String

  // Subcategoría
  subcategoriaCode       String
  subcategoriaNombre     String

  // Arrays de clasificación relacionada
  periodosRelacionados   String[]
  categoriasRelacionadas String[]

  // Anclaje temporal preciso (complementa periodoCode/periodoRango).
  // yearPrincipal: año único más representativo del foco temporal de la pregunta.
  // yearsSecondary: años que la pregunta toca tangencialmente (orden cronológico).
  yearPrincipal          Int?
  yearsSecondary         Int[]    @default([])

  // Entidades segmentadas por tipo. El generador las produce con conteo estricto
  // (5 personas / 3 lugares / 4 conceptos). Permiten construir índices de entidades
  // a nivel de pregunta sin re-procesar el chunk source.
  entidadesPersonas      String[] @default([])
  entidadesLugares       String[] @default([])
  entidadesConceptos     String[] @default([])

  // Ordenamiento inteligente (asignado por questions-orderer)
  ordenPeriodo           Int?
  ordenCategoria         Int?
  ordenSubcategoria      Int?
  temaPeriodo            String?
  temaCategoria          String?
  temaSubcategoria       String?

  // Índice denormalizado del período para sort cronológico real.
  // periodoOrden = posición en PERIOD_OPTIONS (PRE=0, CON=1, ..., POS=14, TRANS=15).
  // Sin este campo, ORDER BY periodoCode queda alfabético — POS antes que PRE, etc.
  periodoOrden           Int     @default(15)

  // ─── Metadata analítica (generada por LLM en mismo tool call) ──────────────
  // Opcionales: preguntas previas al 2026-05-27 no las tienen — la UI debe
  // tolerar null. Se llenan en el momento de generación por questions-generator.
  //
  // tipoPregunta: clasificación analítica del enfoque de la pregunta.
  //   Enum: causal | contrafactual | comparativa | consecuencias_no_obvias
  //         | historiografica | tensiones_internas
  tipoPregunta           String?
  // clusterTematico: frase corta (5-8 palabras) que agrupa preguntas hermanas
  //   del mismo libro bajo un eje narrativo. Útil para vista de detalle y
  //   "preguntas relacionadas". Ej: "Disputa por la frontera amazónica".
  clusterTematico        String?
  // hipotesisImplicita: tesis o debate que la pregunta sostiene/cuestiona
  //   (1-2 líneas). Útil para la vista detalle — explicita el "por qué importa".
  hipotesisImplicita     String? @db.Text
  // escalaGeografica: escala territorial dominante del proceso interrogado.
  //   Enum: local | regional | nacional | latinoamericana | global
  escalaGeografica       String?

  // NOTA: la columna `embedding vector(1536)` existe en BD (ver
  // scripts/apply-migrations.js) pero Prisma no soporta pgvector nativamente.
  // Se accede exclusivamente vía $queryRawUnsafe/$executeRawUnsafe desde
  // src/lib/questions-orderer.ts (ensureQuestionEmbeddings + loadRowsWithEmbeddings).

  justificacion          String   @db.Text

  // Agrupación por batch de generación
  batchId                String

  // Tamaño del batch que generó esta pregunta (N pedido a Claude). Permite saber
  // si un libro tiene preguntas generadas con N=20 antiguo vs N=40 nuevo.
  targetCount            Int      @default(40)

  // Trazabilidad de respuestas: denormalizado para badges/filtros sin joins.
  // Se mantiene desde el código en src/lib/question-stats-sync.ts cada vez que
  // un Deliverable cambia de estado.
  deliverableCount       Int      @default(0)
  completedTemplateIds   String[] @default([])
  lastDeliveredAt        DateTime?

  deliverables           Deliverable[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([documentId])
  @@index([periodoCode])
  @@index([categoriaCode])
  @@index([subcategoriaCode])
  @@index([batchId])
  @@index([periodoCode, ordenPeriodo])
  @@index([categoriaCode, ordenCategoria])
  @@index([subcategoriaCode, ordenSubcategoria])
  @@index([documentId, deliverableCount])
  @@index([periodoOrden, ordenPeriodo])
  @@index([documentId, periodoOrden, ordenPeriodo])
  @@index([tipoPregunta])
  @@index([escalaGeografica])
  @@index([documentId, clusterTematico])
  @@map("questions")
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  pageNumber Int
  chunkIndex Int
  chunkSize  Int
  overlap    Int
  strategy   ChunkStrategy
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // El campo embedding se agrega via SQL manual (vector(1536))
  // Cohere Embed v4 usa 1536 dimensiones
  // Prisma no soporta tipos vector nativamente

  @@index([documentId])
  @@map("chunks")
}

model Configuration {
  id                  String        @id @default(cuid())
  name                String        @default("default")
  chunkSize           Int           @default(512)
  chunkOverlap        Int           @default(64)
  chunkStrategy       ChunkStrategy @default(PARAGRAPH)
  embeddingModel      String        @default("amazon.titan-embed-text-v2:0")
  topK                Int           @default(8)
  similarityThreshold Float         @default(0.4)
  maxTokens           Int           @default(4096)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  conversations       Conversation[]

  @@map("configurations")
}

model Conversation {
  id              String        @id @default(cuid())
  question        String
  answer          String
  modelUsed       String
  templateId      String?
  chunksUsed      Json          @default("[]")
  configurationId String?
  configuration   Configuration? @relation(fields: [configurationId], references: [id])
  createdAt       DateTime      @default(now())

  @@map("conversations")
}

model Deliverable {
  id           String            @id @default(cuid())
  // questionId: opcional. Si viene del flujo /chat (pregunta libre), es null
  // y userQuestion guarda el texto que escribió el usuario.
  questionId   String?
  question     Question?         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userQuestion String?           @db.Text  // Pregunta libre del usuario (chat)
  templateId   String
  status       DeliverableStatus @default(PENDING)
  answer       String            @db.Text @default("")
  modelUsed    String            @default("")
  chunksUsed   Json              @default("[]")
  // metadata libre. Usado por deep_research para guardar plan/subqueries/progress
  // mientras el procesamiento en after() corre en background.
  metadata     Json              @default("{}")
  // source: "batch" (viene de Question del batch) | "chat" (pregunta libre) |
  // "deep_research" (pipeline agéntico multi-step).
  source       String            @default("batch")
  batchId      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // unique constraint solo aplica a entregables de batch (cuando questionId existe).
  // Para chat, no hay restricción — cada conversación es independiente.
  @@unique([questionId, templateId])
  @@index([questionId])
  @@index([templateId])
  @@index([batchId])
  @@index([source])
  @@index([createdAt])
  @@map("deliverables")
}
