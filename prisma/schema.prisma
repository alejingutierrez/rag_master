generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum DeliverableStatus {
  PENDING
  GENERATING
  COMPLETE
  ERROR
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum ChunkStrategy {
  FIXED
  PARAGRAPH
  SENTENCE
}

model Document {
  id        String         @id @default(cuid())
  filename  String
  s3Key     String
  s3Url     String
  fileSize  Int
  pageCount Int            @default(0)
  status    DocumentStatus @default(PENDING)
  metadata  Json           @default("{}")
  enriched  Boolean        @default(false)
  error     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  chunks    Chunk[]
  questions Question[]

  @@map("documents")
}

model Question {
  id                     String   @id @default(cuid())
  documentId             String
  document               Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  questionNumber         Int
  pregunta               String   @db.Text

  // Período histórico principal
  periodoCode            String
  periodoNombre          String
  periodoRango           String

  // Categoría principal
  categoriaCode          String
  categoriaNombre        String

  // Subcategoría
  subcategoriaCode       String
  subcategoriaNombre     String

  // Arrays de clasificación relacionada
  periodosRelacionados   String[]
  categoriasRelacionadas String[]

  justificacion          String   @db.Text

  // Agrupación por batch de generación
  batchId                String

  deliverables           Deliverable[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([documentId])
  @@index([periodoCode])
  @@index([categoriaCode])
  @@index([subcategoriaCode])
  @@index([batchId])
  @@map("questions")
}

model Chunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  pageNumber Int
  chunkIndex Int
  chunkSize  Int
  overlap    Int
  strategy   ChunkStrategy
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // El campo embedding se agrega via SQL manual (vector(1536))
  // Cohere Embed v4 usa 1536 dimensiones
  // Prisma no soporta tipos vector nativamente

  @@index([documentId])
  @@map("chunks")
}

model Configuration {
  id                  String        @id @default(cuid())
  name                String        @default("default")
  chunkSize           Int           @default(512)
  chunkOverlap        Int           @default(64)
  chunkStrategy       ChunkStrategy @default(PARAGRAPH)
  embeddingModel      String        @default("amazon.titan-embed-text-v2:0")
  topK                Int           @default(8)
  similarityThreshold Float         @default(0.4)
  maxTokens           Int           @default(4096)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  conversations       Conversation[]

  @@map("configurations")
}

model Conversation {
  id              String        @id @default(cuid())
  question        String
  answer          String
  modelUsed       String
  templateId      String?
  chunksUsed      Json          @default("[]")
  configurationId String?
  configuration   Configuration? @relation(fields: [configurationId], references: [id])
  createdAt       DateTime      @default(now())

  @@map("conversations")
}

model Deliverable {
  id          String            @id @default(cuid())
  questionId  String
  question    Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  templateId  String
  status      DeliverableStatus @default(PENDING)
  answer      String            @db.Text @default("")
  modelUsed   String            @default("")
  chunksUsed  Json              @default("[]")
  batchId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([questionId, templateId])
  @@index([questionId])
  @@index([templateId])
  @@index([batchId])
  @@map("deliverables")
}
